rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
                    || (isAuthenticated()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['referralCount']));
      allow delete: if isOwner(userId);

      // AI usage counters — owner reads for UI display; writes blocked (Cloud Functions only).
      match /ai_usage/{dateKey} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // Saved Bible verses — per-doc storage, owner-only read/write.
      // Subcollection layout avoids the 1 MiB user-doc cap so users can
      // save unlimited verses without write amplification.
      match /saved_verses/{verseId} {
        allow read, write: if isOwner(userId);
      }

      // Workout history — per-doc storage, owner-only read/write.
      // Per-doc layout avoids re-uploading whole history on every workout.
      match /workouts/{workoutId} {
        allow read, write: if isOwner(userId);
      }

      // Food log — one doc per date (YYYY-MM-DD), owner-only.
      match /food_log/{dateKey} {
        allow read, write: if isOwner(userId);
      }

      // Journal notes — one doc per note id, owner-only.
      match /journal/{noteId} {
        allow read, write: if isOwner(userId);
      }

      // Personal prayers (Bible-tab simplePrayers) — one doc per prayer, owner-only.
      match /prayers_personal/{prayerId} {
        allow read, write: if isOwner(userId);
      }

      // Active todos — one doc per todo, owner-only.
      match /todos/{todoId} {
        allow read, write: if isOwner(userId);
      }

      // Misc per-item subcollections — owner-only.
      match /favorite_verses/{itemId} { allow read, write: if isOwner(userId); }
      match /food_favorites/{itemId} { allow read, write: if isOwner(userId); }
      match /scale_history/{itemId} { allow read, write: if isOwner(userId); }
      match /scheduled_workouts/{itemId} { allow read, write: if isOwner(userId); }
      match /visions/{itemId} { allow read, write: if isOwner(userId); }
      match /prayer_boards/{itemId} { allow read, write: if isOwner(userId); }
    }

    // --- Usernames (username -> userId mapping) ---
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
    }

    // --- Friends ---
    // Uses fields: friendsList (array of UIDs), pendingRequests (array of objects),
    // sentRequests (array of objects). Other users need update access to add/remove
    // friend requests and for account deletion cleanup.
    match /friends/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isAuthenticated();
      allow delete: if isOwner(userId);
    }

    // --- Conversations ---
    // `get` uses the conversation ID (uid1_uid2) so it works even if the
    // document doesn't exist yet. `list` uses the participants array so
    // Firestore can validate the array-contains query constraint.
    match /conversations/{conversationId} {
      allow get: if isAuthenticated()
                 && conversationId.matches('.*' + request.auth.uid + '.*');
      allow list: if isAuthenticated()
                  && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated()
                    && conversationId.matches('.*' + request.auth.uid + '.*');
      allow update: if isAuthenticated()
                    && conversationId.matches('.*' + request.auth.uid + '.*');
      allow delete: if isAuthenticated()
                    && conversationId.matches('.*' + request.auth.uid + '.*');

      match /messages/{messageId} {
        allow read, create, update, delete: if isAuthenticated()
                    && conversationId.matches('.*' + request.auth.uid + '.*');
      }
    }

    // --- Hub Posts ---
    // Other authenticated users need update access to add/remove reactions
    // and for account deletion cleanup (removing deleted user from reactions).
    match /hub_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
    }

    // --- Challenges ---
    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
                    && (resource.data.challengerId == request.auth.uid
                        || resource.data.challengedId == request.auth.uid);
      allow delete: if isAuthenticated()
                    && (resource.data.challengerId == request.auth.uid
                        || resource.data.challengedId == request.auth.uid);
    }

    // --- Prayers ---
    // Other authenticated users need update access to add/remove themselves
    // from prayingUsers and for account deletion cleanup.
    match /prayers/{prayerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated()
                    && resource.data.userId == request.auth.uid;
    }

    // --- Reports ---
    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated()
                    && (resource.data.reporterId == request.auth.uid
                        || resource.data.reportedUserId == request.auth.uid);
    }

    // --- Blocked Users ---
    match /blocked_users/{blockId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
                    && (resource.data.userId == request.auth.uid
                        || resource.data.blockedUserId == request.auth.uid);
    }

    // --- App Feedback ---
    match /app_feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
    }

    // --- User Restrictions (admin-managed) ---
    match /user_restrictions/{restrictionId} {
      allow read: if isAuthenticated();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // --- Verification Codes (Cloud Functions only) ---
    match /verificationCodes/{codeId} {
      allow read, write: if false;
    }

    // --- Password Reset Codes (Cloud Functions only) ---
    match /passwordResetCodes/{codeId} {
      allow read, write: if false;
    }
  }
}
