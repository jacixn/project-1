{
  "expo": {
    "name": "Biblely",
    "slug": "fivefold-ios",
    "version": "1.0.75",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#33C473"
    },
    "scheme": "biblely",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jesusxoi.biblely",
      "buildNumber": "75",
      "infoPlist": {
        "NSCameraUsageDescription": "Biblely needs access to your camera to take a profile photo and scan food for nutrition tracking.",
        "NSPhotoLibraryUsageDescription": "Biblely needs access to your photo library to choose a profile picture or import food photos for nutrition tracking.",
        "NSMicrophoneUsageDescription": "Biblely needs access to your microphone for voice input in chat.",
        "NSUserNotificationsUsageDescription": "Biblely sends prayer reminders and achievement notifications to help you maintain your spiritual journey.",
        "NSBluetoothAlwaysUsageDescription": "Biblely uses Bluetooth to connect to your smart scale for body composition tracking.",
        "NSPhotoLibraryAddUsageDescription": "Biblely needs permission to save images to your photo library.",
        "NSMotionUsageDescription": "Biblely uses motion data for visual effects within the app.",
        "UIBackgroundModes": [
          "remote-notification",
          "bluetooth-central"
        ],
        "UIStatusBarHidden": false,
        "UIViewControllerBasedStatusBarAppearance": false,
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.icloud-container-identifiers": [
          "iCloud.com.jesusxoi.biblely"
        ],
        "com.apple.developer.icloud-services": [
          "CloudKit",
          "CloudDocuments"
        ],
        "com.apple.developer.ubiquity-kvstore-identifier": "$(TeamIdentifierPrefix)com.jesusxoi.biblely"
      },
      "usesIcloudStorage": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#667eea"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.jesusxoi.biblely",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "description": "Faith & Focus Daily - Combine prayer with productivity in a beautiful spiritual companion app",
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#667eea",
          "defaultChannel": "default"
        }
      ],
      "expo-localization",
      "expo-font",
      [
        "expo-alternate-app-icons",
        [
          {
            "name": "Sketch",
            "ios": "./assets/app-icon-sketch.png",
            "android": {
              "foregroundImage": "./assets/app-icon-sketch.png",
              "backgroundColor": "#F5D833"
            }
          },
          {
            "name": "Gradient",
            "ios": "./assets/app-icon-gradient.png",
            "android": {
              "foregroundImage": "./assets/app-icon-gradient.png",
              "backgroundColor": "#F472B6"
            }
          },
          {
            "name": "Pixel",
            "ios": "./assets/app-icon-pixel.png",
            "android": {
              "foregroundImage": "./assets/app-icon-pixel.png",
              "backgroundColor": "#1E293B"
            }
          }
        ]
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f95f19ac-4387-4307-8812-3202ead7a0e9"
      }
    },
    "owner": "jesusxoi"
  }
}
